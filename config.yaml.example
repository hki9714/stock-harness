# ================================================================
#  Stock Harness м„Өм • нҢҢмқј
#  cp config.yaml.example config.yaml нӣ„ к°’мқ„ мұ„мӣҢмЈјм„ёмҡ”.
#  config.yamlмқҖ .gitignoreм—җ мқҳн•ҙ Gitм—җ м»Өл°Ӣлҗҳм§Җ м•ҠмҠөлӢҲлӢӨ.
# ================================================================

# в”Җв”Җ мӢӨн–ү нҷҳкІҪ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
#  local  : лЎңм»¬ PCм—җм„ң Python м§Ғм ‘ мӢӨн–ү (Docker л¶Ҳн•„мҡ”)
#  server : AWS EC2 + Docker л°°нҸ¬
runtime: "local"

# в”Җв”Җ н…”л Ҳк·ёлһЁ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
telegram:
  bot_token: "your_bot_token_here"
  chat_id: "your_chat_id_here"

# в”Җв”Җ AI API в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ai:
  anthropic_api_key: "sk-ant-your-key"
  default_provider: "claude"
  default_model: "claude-sonnet-4-6"

# в”Җв”Җ AWS EC2 (runtime: server мқј л•Ңл§Ң мӮ¬мҡ©) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
aws:
  ec2_host: "your-ec2-ip"
  ec2_user: "ec2-user"
  ec2_pem_path: "~/.ssh/your-key.pem"
  region: "ap-northeast-2"

# в”Җв”Җ GitHub (runtime л¬ҙкҙҖн•ҳкІҢ н•ӯмғҒ м Ғмҡ©) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
github:
  repo_url: "https://github.com/username/stock-harness.git"
  branch: "main"
  auto_commit: true
  auto_commit_delay_seconds: 10

# в”Җв”Җ Docker (runtime: server мқј л•Ңл§Ң мӮ¬мҡ©) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
docker:
  app_port: 8000
  nginx_port: 80
  log_path: "./logs"

# в”Җв”Җ мЈјмӢқ к°җмӢң в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
stock:
  watch_list:
    - "005930"  # мӮјм„ұм „мһҗ
    - "000660"  # SKн•ҳмқҙлӢүмҠӨ
    - "035420"  # NAVER
    - "005380"  # нҳ„лҢҖм°Ё
  volume_surge_ratio: 3.0
  price_surge_pct: 5.0
  sentiment_positive_threshold: 0.65
  sentiment_surge_count: 20
  check_interval_minutes: 30
