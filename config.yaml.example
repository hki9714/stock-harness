# ================================================================
#  Stock Harness 설정 파일
#  cp config.yaml.example config.yaml 후 값을 채워주세요.
#  config.yaml은 .gitignore에 의해 Git에 커밋되지 않습니다.
# ================================================================

# ── 실행 환경 ────────────────────────────────────────────────────
#  local  : 로컬 PC에서 Python 직접 실행 (Docker 불필요)
#  server : AWS EC2 + Docker 배포
runtime: "local"

# ── 텔레그램 ─────────────────────────────────────────────────────
telegram:
  bot_token: "your_bot_token_here"
  chat_id: "your_chat_id_here"

# ── AI API ───────────────────────────────────────────────────────
ai:
  anthropic_api_key: "sk-ant-your-key"
  default_provider: "claude"
  default_model: "claude-sonnet-4-6"

# ── AWS EC2 (runtime: server 일 때만 사용) ───────────────────────
aws:
  ec2_host: "your-ec2-ip"
  ec2_user: "ec2-user"
  ec2_pem_path: "~/.ssh/your-key.pem"
  region: "ap-northeast-2"

# ── GitHub (runtime 무관하게 항상 적용) ─────────────────────────
github:
  repo_url: "https://github.com/username/stock-harness.git"
  branch: "main"
  auto_commit: true
  auto_commit_delay_seconds: 10

# ── Docker (runtime: server 일 때만 사용) ────────────────────────
docker:
  app_port: 8000
  nginx_port: 80
  log_path: "./logs"

# ── 주식 감시 ────────────────────────────────────────────────────
stock:
  watch_list:
    - "005930"  # 삼성전자
    - "000660"  # SK하이닉스
    - "035420"  # NAVER
    - "005380"  # 현대차
  volume_surge_ratio: 3.0
  price_surge_pct: 5.0
  price_drop_pct: 5.0
  sentiment_positive_threshold: 0.65
  sentiment_surge_count: 20
  check_interval_minutes: 30

# ── AI 도구 선언 ──────────────────────────────────────────────────
#  사용할 AI CLI 도구를 지정합니다.
#  bootstrap.py 실행 시 .harness/{ai}/ 의 가이드 파일을
#  프로젝트 루트에 자동으로 복사합니다.
#
#  claude  → CLAUDE.md  (Claude Code)
#  codex   → AGENTS.md  (OpenAI Codex)
#  gemini  → GEMINI.md  (Google Gemini CLI)
harness:
  ai: "claude"
